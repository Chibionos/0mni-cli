{
  "name": "0mni",
  "version": "0.1.0",
  "description": "Multi-agent coding CLI combining Claude, Gemini, and Codex",
  "type": "module",
  "bin": {
    "0mni": "./bin/0mni.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "start": "node ./bin/0mni.js"
  },
  "keywords": ["cli", "ai", "coding-agent", "claude", "gemini", "codex", "tui"],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "meow": "^13.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "cli-highlight": "^2.1.11",
    "chalk": "^5.3.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "gray-matter": "^4.0.3",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsup": "^8.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
